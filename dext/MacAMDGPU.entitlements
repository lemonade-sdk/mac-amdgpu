<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	    transport.pci entitlement match-string MUST exactly match what
	    the embedded provisioning profile allows. Apple's portal granted
	    our team the wildcard "0xFFFFFFFF&0x00000000" (same scope they
	    gave qemu-vfio-apple), not a per-device narrow match.

	    Device-binding restriction to the R9700 happens via the
	    IOPCIPrimaryMatch key in dext/Info.plist — that's a separate
	    mechanism and stays R9700-specific (0x75511002&0xFFFFFFFF).
	-->
	<key>com.apple.developer.driverkit.transport.pci</key>
	<array>
		<dict>
			<key>IOPCIPrimaryMatch</key>
			<string>0xFFFFFFFF&amp;0x00000000</string>
		</dict>
	</array>
	<key>com.apple.developer.driverkit.allow-any-userclient-access</key>
	<true/>
</dict>
</plist>
