<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>DEXT</string>
	<key>CFBundleShortVersionString</key>
	<string>0.0.40</string>
	<key>CFBundleVersion</key>
	<string>40</string>
	<key>OSBundleUsageDescription</key>
	<string>Native AMD GPU driver for Radeon AI PRO R9700 (RDNA4, gfx1201) over Thunderbolt 5.</string>
	<!--
	    OSSystemExtensionCategory — required on macOS Tahoe for sysextd
	    to register a driver-extension as a candidate during activation.
	    Without this key, sysextd rejects the request as "Extension not
	    found in App bundle" even when the .dext is physically present.
	    Same value qemu-vfio-apple ships.
	-->
	<key>OSSystemExtensionCategory</key>
	<string>com.apple.system_extension.driver_extension</string>
	<key>IOKitPersonalities</key>
	<dict>
		<key>MacAMDGPU</key>
		<dict>
			<key>IOClass</key>
			<string>IOUserService</string>
			<key>IOProviderClass</key>
			<string>IOPCIDevice</string>
			<key>IOUserClass</key>
			<string>MacAMDGPU</string>
			<key>IOUserServerName</key>
			<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
			<key>IOPCITunnelCompatible</key>
			<true/>
			<!--
			    Match AMD vendor (VID=0x1002) only. Format is
			    "value&mask"; mask 0x0000FFFF means only the low 16 bits
			    (vendor ID) are required to match. Apple's wildcard
			    transport.pci entitlement scope (0xFFFFFFFF&0x00000000)
			    permits this narrowing.
			-->
			<key>IOPCIPrimaryMatch</key>
			<string>0x00001002&amp;0x0000FFFF</string>
			<!-- Class match: only graphics-class PCI devices
			     (class-code 0x030000 / display controller). -->
			<key>IOPCIClassMatch</key>
			<string>0x03000000&amp;0xFF000000</string>
			<!--
			    IOProbeScore — sentinel above default (0). Wins against
			    the qemu-vfio-apple VFIOUserPCIDriver dext which matches
			    every PCI device (0xFFFFFFFF&0x00000000) when both dexts
			    are installed. If both are loaded and try to claim the
			    R9700 simultaneously the more-specific match should win
			    on its own — this is belt-and-braces.
			-->
			<key>IOProbeScore</key>
			<integer>10000</integer>
			<key>MacAMDGPUUserClientProperties</key>
			<dict>
				<key>IOClass</key>
				<string>IOUserUserClient</string>
				<key>IOUserClass</key>
				<string>MacAMDGPUUserClient</string>
			</dict>
		</dict>
	</dict>
</dict>
</plist>
