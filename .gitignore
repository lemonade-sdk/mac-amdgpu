# Vendored third-party trees — referenced for porting, not published.
upstream/linux/
upstream/linux-firmware/
upstream/mesa/
upstream/

# Internal porting notes / audit reports — not for public view.
docs/

# Firmware blobs — vendored under firmware/. Sourced from
# linux-firmware (license headers in firmware/LICENSE.* preserved).

# Build output.
build/
build.log
*.dSYM/

# xcodegen-managed — regenerate via scripts/build.sh
*.xcodeproj/
MacAMDGPU.xcodeproj/
*.xcworkspace/
xcuserdata/
DerivedData/
~/Library/Developer/Xcode/DerivedData/MacAMDGPU-*

# macOS junk.
.DS_Store

# Temp scratch files written by host/scripts during bringup.
/tmp/dext_open_trace.log
/tmp/macamdgpu_activate.log
/tmp/ping_entitlements.plist
/tmp/minimal_dext_entitlements.plist
